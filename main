local runService = game:GetService("RunService")
local players = game:GetService("Players")
local workspace = game:GetService("Workspace")

local localPlayer = players.LocalPlayer
local camera = workspace.CurrentCamera
local viewportSize = camera.ViewportSize
local container = Instance.new("Folder", gethui and gethui() or game:GetService("CoreGui"))

local floor, round, find, clear = math.floor, math.round, table.find, table.clear
local wtvp = camera.WorldToViewportPoint
local findFirstChildOfClass = workspace.FindFirstChildOfClass

local function createSafeDrawing(class)
	local success, drawing = pcall(Drawing.new, class)
	if not success then return {} end
	return drawing
end

local EspObject = {}
EspObject.__index = EspObject

function EspObject.new(player, interface)
	local self = setmetatable({}, EspObject)
	self.player = player
	self.interface = interface
	self.drawings = {
		box = createSafeDrawing("Square"),
		name = createSafeDrawing("Text"),
		distance = createSafeDrawing("Text"),
		healthBar = createSafeDrawing("Line"),
		tracer = createSafeDrawing("Line")
	}
	self.highlight = Instance.new("Highlight", container)
	
	self.connection = runService.RenderStepped:Connect(function()
		self:Update()
	end)
	return self
end

function EspObject:Update()
	local char = self.player.Character
	local interface = self.interface
	local options = interface.teamSettings[interface.isFriendly(self.player) and "friendly" or "enemy"]
	
	if not (options.enabled and char and char:FindFirstChild("HumanoidRootPart")) then
		for _, d in next, self.drawings do d.Visible = false end
		self.highlight.Enabled = false
		return
	end

	local root = char.HumanoidRootPart
	local screenPoint, onScreen = wtvp(camera, root.Position)
	local depth = screenPoint.Z
	
	if interface.sharedSettings.limitDistance and depth > interface.sharedSettings.maxDistance then
		onScreen = false
	end

	self.highlight.Enabled = options.chams
	if options.chams then
		self.highlight.Adornee = char
		self.highlight.FillColor = options.chamsFillColor[1] or Color3.new(1,1,1)
		self.highlight.FillTransparency = options.chamsFillColor[2] or 0.5
		self.highlight.OutlineColor = options.chamsOutlineColor[1] or Color3.new(1,1,1)
	end

	if onScreen and depth > 0 then
		local size = Vector2.new(2000 / depth, 2000 / depth)
		local tl = Vector2.new(screenPoint.X - size.X / 2, screenPoint.Y - size.Y / 2)
		
		local box = self.drawings.box
		box.Visible = options.box
		box.Position = tl
		box.Size = size
		box.Color = options.boxColor[1] or Color3.new(1,1,1)
		box.Transparency = options.boxColor[2] or 1

		local nm = self.drawings.name
		nm.Visible = options.name
		nm.Text = self.player.Name
		nm.Position = Vector2.new(screenPoint.X, tl.Y - 15)
		nm.Center = true
		nm.Outline = true
		nm.Color = options.nameColor[1] or Color3.new(1,1,1)

		local dist = self.drawings.distance
		dist.Visible = options.distance
		dist.Text = "[" .. round(depth) .. "m]"
		dist.Position = Vector2.new(screenPoint.X, tl.Y + size.Y + 5)
		dist.Center = true
		dist.Outline = true
		dist.Color = options.distanceColor[1] or Color3.new(1,1,1)

		local hb = self.drawings.healthBar
		hb.Visible = options.healthBar
		local hum = findFirstChildOfClass(char, "Humanoid")
		if hum then
			local healthPercent = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
			hb.From = Vector2.new(tl.X - 5, tl.Y + size.Y)
			hb.To = Vector2.new(tl.X - 5, tl.Y + size.Y - (size.Y * healthPercent))
			hb.Color = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(0, 255, 0), healthPercent)
			hb.Thickness = 2
		end

		local tr = self.drawings.tracer
		tr.Visible = options.tracer
		tr.From = Vector2.new(viewportSize.X / 2, viewportSize.Y)
		tr.To = Vector2.new(screenPoint.X, screenPoint.Y)
		tr.Color = options.tracerColor[1] or Color3.new(1,1,1)
	else
		for _, d in next, self.drawings do d.Visible = false end
	end
end

function EspObject:Destruct()
	self.connection:Disconnect()
	for _, d in next, self.drawings do d:Remove() end
	self.highlight:Destroy()
end

local EspInterface = {
	_objectCache = {},
	sharedSettings = { limitDistance = false, maxDistance = 500 },
	teamSettings = {
		enemy = {
			enabled = true, box = true, boxColor = {Color3.fromRGB(255, 0, 0), 1},
			name = true, nameColor = {Color3.fromRGB(255, 255, 255), 1},
			distance = true, distanceColor = {Color3.fromRGB(255, 255, 255), 1},
			healthBar = true, tracer = false, tracerColor = {Color3.fromRGB(255, 0, 0), 1},
			chams = true, chamsFillColor = {Color3.fromRGB(255, 0, 0), 0.5}, chamsOutlineColor = {Color3.fromRGB(255, 255, 255), 0}
		},
		friendly = {
			enabled = false, box = true, boxColor = {Color3.fromRGB(0, 255, 0), 1},
			name = true, nameColor = {Color3.fromRGB(255, 255, 255), 1},
			distance = true, distanceColor = {Color3.fromRGB(255, 255, 255), 1},
			healthBar = true, tracer = false, tracerColor = {Color3.fromRGB(0, 255, 0), 1},
			chams = false, chamsFillColor = {Color3.fromRGB(0, 255, 0), 0.5}, chamsOutlineColor = {Color3.fromRGB(255, 255, 255), 0}
		}
	}
}

function EspInterface.isFriendly(player)
	if localPlayer.Team == nil then 
		return false -- If the game doesn't use teams, treat everyone as an enemy
	end
	return player.Team == localPlayer.Team
end

function EspInterface.Load()
	local function add(p)
		if p ~= localPlayer then EspInterface._objectCache[p] = EspObject.new(p, EspInterface) end
	end
	for _, p in next, players:GetPlayers() do add(p) end
	EspInterface.added = players.PlayerAdded:Connect(add)
	EspInterface.removed = players.PlayerRemoving:Connect(function(p)
		if EspInterface._objectCache[p] then
			EspInterface._objectCache[p]:Destruct()
			EspInterface._objectCache[p] = nil
		end
	end)
end

function EspInterface.Unload()
	if EspInterface.added then EspInterface.added:Disconnect() EspInterface.added = nil end
	if EspInterface.removed then EspInterface.removed:Disconnect() EspInterface.removed = nil end
	for p, obj in next, EspInterface._objectCache do
		obj:Destruct()
		EspInterface._objectCache[p] = nil
	end
end

return EspInterface
