local runService = game:GetService("RunService")
local players = game:GetService("Players")
local workspace = game:GetService("Workspace")
local teams = game:GetService("Teams")
local coreGui = gethui and gethui() or game:GetService("CoreGui")

local localPlayer = players.LocalPlayer
local camera = workspace.CurrentCamera

local gui = Instance.new("ScreenGui")
gui.Name = "ESPGui"
gui.IgnoreGuiInset = true
gui.Parent = coreGui

local highlightContainer = Instance.new("Folder")
highlightContainer.Name = "ESPHighlights"
highlightContainer.Parent = coreGui

local hasDrawing = pcall(function() Drawing.new("Line") end)

local function createDrawing(class)
	if hasDrawing then
		local success, obj = pcall(Drawing.new, class)
		if success then return obj end
	end

	local obj = {Visible = false, Color = Color3.new(1,1,1), Transparency = 1, ZIndex = 1}
	if class == "Line" then
		local frame = Instance.new("Frame")
		frame.AnchorPoint = Vector2.new(0.5, 0.5)
		frame.BorderSizePixel = 0
		frame.Parent = gui
		obj.Instance = frame
		obj.From = Vector2.new()
		obj.To = Vector2.new()
		obj.Thickness = 1
		setmetatable(obj, {__newindex = function(t, k, v)
			rawset(t, k, v)
			if k == "Visible" then frame.Visible = v
			elseif k == "Color" then frame.BackgroundColor3 = v
			elseif k == "Transparency" then frame.BackgroundTransparency = 1 - v
			elseif k == "From" or k == "To" then
				local dir = t.To - t.From
				local center = (t.To + t.From) / 2
				frame.Position = UDim2.fromOffset(center.X, center.Y)
				frame.Size = UDim2.fromOffset(dir.Magnitude, t.Thickness)
				frame.Rotation = math.deg(math.atan2(dir.Y, dir.X))
			elseif k == "Thickness" then
				local dir = t.To - t.From
				frame.Size = UDim2.fromOffset(dir.Magnitude, v)
			end
		end})
	elseif class == "Square" then
		local frame = Instance.new("Frame")
		frame.BackgroundTransparency = 1
		frame.Parent = gui
		local stroke = Instance.new("UIStroke")
		stroke.Parent = frame
		obj.Instance = frame
		obj.Size = Vector2.new()
		obj.Position = Vector2.new()
		setmetatable(obj, {__newindex = function(t, k, v)
			rawset(t, k, v)
			if k == "Visible" then frame.Visible = v
			elseif k == "Color" then stroke.Color = v
			elseif k == "Transparency" then stroke.Transparency = 1 - v
			elseif k == "Size" then frame.Size = UDim2.fromOffset(v.X, v.Y)
			elseif k == "Position" then frame.Position = UDim2.fromOffset(v.X, v.Y)
			end
		end})
	end

	obj.Remove = function(self)
		if self.Instance then self.Instance:Destroy() end
	end
	return obj
end

local function createBillboard()
	local bb = Instance.new("BillboardGui")
	bb.Name = "ESPBillboard"
	bb.AlwaysOnTop = true
	bb.Size = UDim2.fromOffset(200, 40)
	bb.StudsOffset = Vector3.new(0, 3.2, 0)
	bb.ResetOnSpawn = false
	bb.Enabled = false
	bb.Parent = coreGui

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "NameLabel"
	nameLabel.AnchorPoint = Vector2.new(0.5, 1)
	nameLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
	nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Font = Enum.Font.Code
	nameLabel.TextSize = 13
	nameLabel.TextColor3 = Color3.new(1, 1, 1)
	nameLabel.TextStrokeTransparency = 0
	nameLabel.Text = ""
	nameLabel.Parent = bb

	local distLabel = Instance.new("TextLabel")
	distLabel.Name = "DistLabel"
	distLabel.AnchorPoint = Vector2.new(0.5, 0)
	distLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
	distLabel.Size = UDim2.new(1, 0, 0.5, 0)
	distLabel.BackgroundTransparency = 1
	distLabel.Font = Enum.Font.Code
	distLabel.TextSize = 11
	distLabel.TextColor3 = Color3.new(1, 1, 1)
	distLabel.TextStrokeTransparency = 0
	distLabel.Text = ""
	distLabel.Parent = bb

	return bb, nameLabel, distLabel
end

local EspInterface = {
	_cache = {},
	shared = { limitDistance = false, maxDistance = 500 },
	teams = {
		enemy = {
			enabled = false, box = true, boxColor = {Color3.fromRGB(255, 0, 0), 1},
			name = true, nameColor = {Color3.fromRGB(255, 255, 255), 1},
			distance = true, distanceColor = {Color3.fromRGB(255, 255, 255), 1},
			healthBar = true, tracer = false, tracerColor = {Color3.fromRGB(255, 0, 0), 1},
			chams = true, chamsFillColor = {Color3.fromRGB(255, 0, 0), 0.5}, chamsOutlineColor = {Color3.fromRGB(255, 255, 255), 0}
		},
		friendly = {
			enabled = false, box = true, boxColor = {Color3.fromRGB(0, 255, 0), 1},
			name = true, nameColor = {Color3.fromRGB(255, 255, 255), 1},
			distance = true, distanceColor = {Color3.fromRGB(255, 255, 255), 1},
			healthBar = true, tracer = false, tracerColor = {Color3.fromRGB(0, 255, 0), 1},
			chams = false, chamsFillColor = {Color3.fromRGB(0, 255, 0), 0.5}, chamsOutlineColor = {Color3.fromRGB(255, 255, 255), 0}
		},
		neutral = {
			enabled = true, box = true, boxColor = {Color3.fromRGB(150, 150, 150), 1},
			name = true, nameColor = {Color3.fromRGB(255, 255, 255), 1},
			distance = true, distanceColor = {Color3.fromRGB(255, 255, 255), 1},
			healthBar = true, tracer = false, tracerColor = {Color3.fromRGB(150, 150, 150), 1},
			chams = false, chamsFillColor = {Color3.fromRGB(150, 150, 150), 0.5}, chamsOutlineColor = {Color3.fromRGB(255, 255, 255), 0}
		}
	}
}

local function getTeamColor(player, optionsColor)
    if not localPlayer.Team or not player.Team or #teams:GetChildren() == 0 then
        return optionsColor[1] or Color3.fromRGB(150, 150, 150)
    end
    return optionsColor[1] or Color3.new(1, 1, 1)
end

local function getEspState(player)
    if not localPlayer.Team or not player.Team or #teams:GetChildren() == 0 then
        return EspInterface.teams.neutral
    end
    return EspInterface.teams[player.Team == localPlayer.Team and "friendly" or "enemy"]
end

local function isLocalPlayer(player)
	local lp = players.LocalPlayer
	if lp then
		if player == lp then return true end
		if player.UserId == lp.UserId then return true end
	end
	if localPlayer then
		if player == localPlayer then return true end
		if player.UserId == localPlayer.UserId then return true end
	end
	return false
end

local function createEsp(player)
	if isLocalPlayer(player) then return end

	local billboard, nameLabel, distLabel = createBillboard()

	local obj = {
		player = player,
		billboard = billboard,
		nameLabel = nameLabel,
		distLabel = distLabel,
		drawings = {
			box        = createDrawing("Square"),
			healthBar  = createDrawing("Line"),
			tracer     = createDrawing("Line")
		},
		highlight = Instance.new("Highlight")
	}
	obj.highlight.Parent = highlightContainer
	EspInterface._cache[player] = obj
end

local function removeEsp(player)
	local obj = EspInterface._cache[player]
	if obj then
		for _, d in next, obj.drawings do d:Remove() end
		obj.highlight:Destroy()
		obj.billboard:Destroy()
		EspInterface._cache[player] = nil
	end
end

local function updateEsp()
	camera = workspace.CurrentCamera
	local viewportSize = camera.ViewportSize

	local lp = players.LocalPlayer
	if lp and EspInterface._cache[lp] then removeEsp(lp) end
	if lp then
		for player in next, EspInterface._cache do
			if player.UserId == lp.UserId then removeEsp(player) break end
		end
	end

	for player, obj in next, EspInterface._cache do
		local char = player.Character
		local options = getEspState(player)

		if not (options.enabled and char
			and char:FindFirstChild("HumanoidRootPart")
			and char:FindFirstChild("Head")
			and player.Parent) then
			for _, d in next, obj.drawings do d.Visible = false end
			obj.highlight.Enabled = false
			obj.billboard.Enabled = false
			continue
		end

		local root = char.HumanoidRootPart
		local head = char.Head
		local hum  = char:FindFirstChildOfClass("Humanoid")

		if not hum or hum.Health <= 0 then
			for _, d in next, obj.drawings do d.Visible = false end
			obj.highlight.Enabled = false
			obj.billboard.Enabled = false
			continue
		end

		local screenPoint, onScreen = camera:WorldToViewportPoint(root.Position)
		local depth = screenPoint.Z

		if EspInterface.shared.limitDistance and depth > EspInterface.shared.maxDistance then
			onScreen = false
		end

		obj.highlight.Enabled = options.chams
		if options.chams then
			obj.highlight.Adornee = char
			obj.highlight.FillColor = getTeamColor(player, options.chamsFillColor)
			obj.highlight.FillTransparency = options.chamsFillColor[2] or 0.5
			obj.highlight.OutlineColor = options.chamsOutlineColor[1] or Color3.new(1, 1, 1)
		end

		local showLabels = onScreen and depth > 0
		obj.billboard.Enabled = showLabels and (options.name or options.distance)
		if showLabels then
			obj.billboard.Adornee = head

			obj.nameLabel.Visible = options.name
			obj.nameLabel.Text = options.name and player.DisplayName .. " (" .. player.Name .. ")"
			obj.nameLabel.TextColor3 = getTeamColor(player, options.nameColor)

			obj.distLabel.Visible = options.distance
			obj.distLabel.Text = options.distance and ("[" .. math.round(depth) .. "m]") or ""
			obj.distLabel.TextColor3 = getTeamColor(player, options.distanceColor)
		end

		if onScreen and depth > 0 then
			local headPoint = camera:WorldToViewportPoint(head.Position + Vector3.new(0, head.Size.Y / 2, 0))
			local height = math.abs(headPoint.Y - screenPoint.Y) * 2.2
			local width  = height * 0.65
			local tl     = Vector2.new(screenPoint.X - width / 2, screenPoint.Y - height / 2)

			local box = obj.drawings.box
			box.Visible = options.box
			box.Position = tl
			box.Size = Vector2.new(width, height)
			box.Color = getTeamColor(player, options.boxColor)
			box.Transparency = options.boxColor[2] or 1

			local hb = obj.drawings.healthBar
			hb.Visible = options.healthBar
			local hp = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
			hb.From = Vector2.new(tl.X - 6, tl.Y + height)
			hb.To   = Vector2.new(tl.X - 6, tl.Y + height - (height * hp))
			hb.Color = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(0, 255, 0), hp)
			hb.Thickness = 2

			local tr = obj.drawings.tracer
			tr.Visible = options.tracer
			tr.From  = Vector2.new(viewportSize.X / 2, viewportSize.Y)
			tr.To    = Vector2.new(screenPoint.X, screenPoint.Y)
			tr.Color = getTeamColor(player, options.tracerColor)
		else
			for _, d in next, obj.drawings do d.Visible = false end
		end
	end
end

function EspInterface.Load()
	for _, p in next, players:GetPlayers() do createEsp(p) end
	EspInterface.added   = players.PlayerAdded:Connect(createEsp)
	EspInterface.removed = players.PlayerRemoving:Connect(removeEsp)
	EspInterface.loop    = runService.RenderStepped:Connect(updateEsp)
end

function EspInterface.Unload()
	if EspInterface.added   then EspInterface.added:Disconnect() end
	if EspInterface.removed then EspInterface.removed:Disconnect() end
	if EspInterface.loop    then EspInterface.loop:Disconnect() end
	for p in next, EspInterface._cache do removeEsp(p) end
	highlightContainer:ClearAllChildren()
	gui:Destroy()
end

return EspInterface
