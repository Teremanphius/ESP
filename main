-- Localize globals used in the hot path to avoid repeated _ENV lookups
local runService  = game:GetService("RunService")
local players     = game:GetService("Players")
local workspace   = game:GetService("Workspace")
local teams       = game:GetService("Teams")
local coreGui     = gethui and gethui() or game:GetService("CoreGui")

local localPlayer = players.LocalPlayer
local camera      = workspace.CurrentCamera

-- Math / constructor locals (avoids global table lookup every call in updateEsp)
local mathAbs     = math.abs
local mathClamp   = math.clamp
local mathRound   = math.round
local mathDeg     = math.deg
local mathAtan2   = math.atan2
local tickFn      = tick
local v2New       = Vector2.new
local v3New       = Vector3.new
local c3HSV       = Color3.fromHSV
local c3RGB       = Color3.fromRGB
local udim2Off    = UDim2.fromOffset

-- Pre-baked constants re-used every frame
local HP_RED      = c3RGB(255, 0, 0)
local HP_GREEN    = c3RGB(0, 255, 0)
local WHITE       = Color3.new(1, 1, 1)

local gui = Instance.new("ScreenGui")
gui.Name = "ESPGui"
gui.IgnoreGuiInset = true
gui.Parent = coreGui

local highlightContainer = Instance.new("Folder")
highlightContainer.Name = "ESPHighlights"
highlightContainer.Parent = coreGui

local hasDrawing = pcall(function() Drawing.new("Line") end)

local function createDrawing(class)
	if hasDrawing then
		local success, obj = pcall(Drawing.new, class)
		if success then return obj end
	end

	local obj = {Visible = false, Color = WHITE, Transparency = 1, ZIndex = 1}
	if class == "Line" then
		local frame = Instance.new("Frame")
		frame.AnchorPoint = v2New(0.5, 0.5)
		frame.BorderSizePixel = 0
		frame.Parent = gui
		obj.Instance  = frame
		obj.From      = v2New()
		obj.To        = v2New()
		obj.Thickness = 1
		setmetatable(obj, {__newindex = function(t, k, v)
			rawset(t, k, v)
			if k == "Visible" then frame.Visible = v
			elseif k == "Color" then frame.BackgroundColor3 = v
			elseif k == "Transparency" then frame.BackgroundTransparency = 1 - v
			elseif k == "From" or k == "To" then
				local dir    = t.To - t.From
				local center = (t.To + t.From) / 2
				frame.Position = udim2Off(center.X, center.Y)
				frame.Size     = udim2Off(dir.Magnitude, t.Thickness)
				frame.Rotation = mathDeg(mathAtan2(dir.Y, dir.X))
			elseif k == "Thickness" then
				local dir = t.To - t.From
				frame.Size = udim2Off(dir.Magnitude, v)
			end
		end})
	elseif class == "Square" then
		local frame = Instance.new("Frame")
		frame.BackgroundTransparency = 1
		frame.Parent = gui
		local stroke = Instance.new("UIStroke")
		stroke.Parent = frame
		obj.Instance = frame
		obj.Size     = v2New()
		obj.Position = v2New()
		setmetatable(obj, {__newindex = function(t, k, v)
			rawset(t, k, v)
			if k == "Visible" then frame.Visible = v
			elseif k == "Color" then stroke.Color = v
			elseif k == "Transparency" then stroke.Transparency = 1 - v
			elseif k == "Size" then frame.Size = udim2Off(v.X, v.Y)
			elseif k == "Position" then frame.Position = udim2Off(v.X, v.Y)
			end
		end})
	end

	obj.Remove = function(self)
		if self.Instance then self.Instance:Destroy() end
	end
	return obj
end

local function createBillboard()
	local bb = Instance.new("BillboardGui")
	bb.Name          = "ESPBillboard"
	bb.AlwaysOnTop   = true
	bb.Size          = UDim2.fromOffset(200, 40)
	bb.StudsOffset   = v3New(0, 3.2, 0)
	bb.ResetOnSpawn  = false
	bb.Enabled       = false
	bb.Parent        = coreGui

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name                  = "NameLabel"
	nameLabel.AnchorPoint           = v2New(0.5, 1)
	nameLabel.Position              = UDim2.new(0.5, 0, 0.5, 0)
	nameLabel.Size                  = UDim2.new(1, 0, 0.5, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Font                  = Enum.Font.Code
	nameLabel.TextSize              = 13
	nameLabel.TextColor3            = WHITE
	nameLabel.TextStrokeTransparency = 0
	nameLabel.Text                  = ""
	nameLabel.Parent                = bb

	local distLabel = Instance.new("TextLabel")
	distLabel.Name                  = "DistLabel"
	distLabel.AnchorPoint           = v2New(0.5, 0)
	distLabel.Position              = UDim2.new(0.5, 0, 0.5, 0)
	distLabel.Size                  = UDim2.new(1, 0, 0.5, 0)
	distLabel.BackgroundTransparency = 1
	distLabel.Font                  = Enum.Font.Code
	distLabel.TextSize              = 11
	distLabel.TextColor3            = WHITE
	distLabel.TextStrokeTransparency = 0
	distLabel.Text                  = ""
	distLabel.Parent                = bb

	return bb, nameLabel, distLabel
end

local RAINBOW_OFFSETS = {
	box      = 0,
	name     = 0.15,
	distance = 0.30,
	tracer   = 0.45,
	chams    = 0.60,
}

-- EspInterface declared before helper functions that reference it
local EspInterface = {
	_cache = {},
	shared = {
		limitDistance     = false,
		maxDistance       = 500,
		rainbowSpeed      = 0.5,
		rainbowSaturation = 1.0,
		rainbow = {
			box      = false,
			name     = false,
			distance = false,
			tracer   = false,
			chams    = false,
		},
	},
	teams = {
		enemy = {
			enabled = false,
			box = true,        boxColor = {c3RGB(255, 0, 0), 1},
			name = true,       nameColor = {c3RGB(255, 255, 255), 1},
			distance = true,   distanceColor = {c3RGB(255, 255, 255), 1},
			healthBar = true,
			tracer = false,    tracerColor = {c3RGB(255, 0, 0), 1},
			chams = true,
			chamsFillColor = {c3RGB(255, 0, 0), 0.5},
			chamsOutlineColor = {c3RGB(255, 255, 255), 0},
		},
		friendly = {
			enabled = false,
			box = true,        boxColor = {c3RGB(0, 255, 0), 1},
			name = true,       nameColor = {c3RGB(255, 255, 255), 1},
			distance = true,   distanceColor = {c3RGB(255, 255, 255), 1},
			healthBar = true,
			tracer = false,    tracerColor = {c3RGB(0, 255, 0), 1},
			chams = false,
			chamsFillColor = {c3RGB(0, 255, 0), 0.5},
			chamsOutlineColor = {c3RGB(255, 255, 255), 0},
		},
		neutral = {
			enabled = true,
			box = true,        boxColor = {c3RGB(150, 150, 150), 1},
			name = true,       nameColor = {c3RGB(255, 255, 255), 1},
			distance = true,   distanceColor = {c3RGB(255, 255, 255), 1},
			healthBar = true,
			tracer = false,    tracerColor = {c3RGB(150, 150, 150), 1},
			chams = false,
			chamsFillColor = {c3RGB(150, 150, 150), 0.5},
			chamsOutlineColor = {c3RGB(255, 255, 255), 0},
		},
	},
}

-- Single definition, after EspInterface exists
local function getRainbowColor()
	local s = EspInterface.shared
	return c3HSV((tickFn() * s.rainbowSpeed) % 1, s.rainbowSaturation, 1)
end

local function resolveFeatureColor(rainbow, options, colorKey, featureKey)
	-- `rainbow` is pre-fetched by the caller to avoid repeated shared.rainbow lookups
	if rainbow[featureKey] then
		return getRainbowColor()
	end
	local ct = options[colorKey]
	return ct and ct[1] or WHITE
end

-- Uses FindFirstChildOfClass instead of #GetChildren() which allocates a table
local function getEspState(player)
	if not localPlayer.Team or not player.Team
		or not teams:FindFirstChildOfClass("Team") then
		return EspInterface.teams.neutral
	end
	return EspInterface.teams[player.Team == localPlayer.Team and "friendly" or "enemy"]
end

local function createEsp(player)
	-- Single, cheap identity check — localPlayer is already upvalued
	if player == localPlayer then return end

	local billboard, nameLabel = createBillboard()

	local obj = {
		player    = player,
		billboard = billboard,
		nameLabel = nameLabel,
		drawings  = {
			box       = createDrawing("Square"),
			healthBar = createDrawing("Line"),
			tracer    = createDrawing("Line"),
			distText  = Drawing.new("Text"),
		},
		highlight = Instance.new("Highlight"),
	}

	local dt = obj.drawings.distText
	dt.Size    = 12
	dt.Font    = Drawing.Fonts.Monospace
	dt.Outline = false
	dt.Center  = true
	dt.Color   = c3RGB(200, 200, 200)

	EspInterface._cache[player] = obj
end

local function removeEsp(player)
	local obj = EspInterface._cache[player]
	if obj then
		for _, d in next, obj.drawings do d:Remove() end
		obj.highlight:Destroy()
		obj.billboard:Destroy()
		EspInterface._cache[player] = nil
	end
end

local function hideAll(obj)
	local d = obj.drawings
	d.box.Visible       = false
	d.healthBar.Visible = false
	d.tracer.Visible    = false
	d.distText.Visible  = false
	obj.highlight.Enabled = false
	obj.billboard.Enabled = false
end

local function updateEsp()
	camera = workspace.CurrentCamera
	local viewportSize = camera.ViewportSize

	-- Cache shared settings and rainbow table once per frame
	local shared       = EspInterface.shared
	local rainbow      = shared.rainbow
	local limitDist    = shared.limitDistance
	local maxDist      = shared.maxDistance
	-- Tracer origin is constant within the frame; compute once outside the player loop
	local tracerOrigin = v2New(viewportSize.X * 0.5, viewportSize.Y)

	for player, obj in next, EspInterface._cache do
		local char    = player.Character
		local options = getEspState(player)

		-- Guard: disabled, missing parts, or player left
		if not (options.enabled and char
			and char:FindFirstChild("HumanoidRootPart")
			and char:FindFirstChild("Head")
			and player.Parent) then
			hideAll(obj)
			continue
		end

		local root = char.HumanoidRootPart
		local head = char.Head
		local hum  = char:FindFirstChildOfClass("Humanoid")

		if not hum or hum.Health <= 0 then
			hideAll(obj)
			continue
		end

		-- Two WorldToViewportPoint calls instead of three:
		-- topSP  = top of head,  botSP = feet (root - 3)
		-- Center X is the average of their screen Xs (accurate for upright characters)
		local topSP = camera:WorldToViewportPoint(head.Position + v3New(0, head.Size.Y * 0.5, 0))
		local botSP = camera:WorldToViewportPoint(root.Position - v3New(0, 3, 0))

		local depth    = (topSP.Z + botSP.Z) * 0.5
		local centerX  = (topSP.X + botSP.X) * 0.5
		local onScreen = topSP.Z > 0

		if limitDist and depth > maxDist then
			onScreen = false
		end

		-- Chams (highlight) — independent of onScreen
		if options.chams then
			local hl = obj.highlight
			hl.FillColor        = resolveFeatureColor(rainbow, options, "chamsFillColor", "chams")
			hl.FillTransparency = options.chamsFillColor[2] or 0.5
			hl.OutlineColor     = options.chamsOutlineColor[1] or WHITE
			hl.Enabled          = true
			hl.Parent           = char
		else
			local hl = obj.highlight
			hl.Enabled = false
			hl.Parent  = nil
		end

		if onScreen then
			local height = mathAbs(topSP.Y - botSP.Y)
			local width  = height * 0.6
			local tlX    = centerX - width * 0.5
			local tlY    = topSP.Y

			-- Billboard / name label
			local showName = options.name
			obj.billboard.Enabled = showName
			if showName then
				obj.billboard.Adornee    = head
				obj.nameLabel.Visible    = true
				obj.nameLabel.Text       = player.DisplayName .. " (" .. player.Name .. ")"
				obj.nameLabel.TextColor3 = resolveFeatureColor(rainbow, options, "nameColor", "name")
			else
				obj.nameLabel.Visible = false
				obj.nameLabel.Text    = ""
			end

			-- Box
			local box      = obj.drawings.box
			box.Visible    = options.box
			box.Position   = v2New(tlX, tlY)
			box.Size       = v2New(width, height)
			box.Color      = resolveFeatureColor(rainbow, options, "boxColor", "box")
			box.Transparency = options.boxColor[2] or 1

			-- Health bar
			local hb    = obj.drawings.healthBar
			hb.Visible  = options.healthBar
			local hp    = mathClamp(hum.Health / hum.MaxHealth, 0, 1)
			local hbX   = tlX - 6
			local hbBot = tlY + height
			hb.From      = v2New(hbX, hbBot)
			hb.To        = v2New(hbX, hbBot - height * hp)
			hb.Color     = HP_RED:Lerp(HP_GREEN, hp)
			hb.Thickness = 2

			-- Tracer
			local tr    = obj.drawings.tracer
			tr.Visible  = options.tracer
			tr.From     = tracerOrigin
			tr.To       = v2New(centerX, (topSP.Y + botSP.Y) * 0.5)
			tr.Color    = resolveFeatureColor(rainbow, options, "tracerColor", "tracer")

			-- Distance text
			local dt    = obj.drawings.distText
			dt.Visible  = options.distance
			if options.distance then
				dt.Text     = "[" .. mathRound(depth) .. "m]"
				dt.Color    = resolveFeatureColor(rainbow, options, "distanceColor", "distance")
				dt.Position = v2New(centerX, tlY + height + 4)
			end
		else
			local d = obj.drawings
			d.box.Visible       = false
			d.healthBar.Visible = false
			d.tracer.Visible    = false
			d.distText.Visible  = false
			obj.billboard.Enabled = false
		end
	end
end

function EspInterface.Load()
	for _, p in next, players:GetPlayers() do createEsp(p) end
	EspInterface.added   = players.PlayerAdded:Connect(createEsp)
	EspInterface.removed = players.PlayerRemoving:Connect(removeEsp)
	EspInterface.loop    = runService.RenderStepped:Connect(updateEsp)
end

function EspInterface.Unload()
	if EspInterface.added   then EspInterface.added:Disconnect() end
	if EspInterface.removed then EspInterface.removed:Disconnect() end
	if EspInterface.loop    then EspInterface.loop:Disconnect() end
	for p in next, EspInterface._cache do removeEsp(p) end
	highlightContainer:ClearAllChildren()
	gui:Destroy()
end

return EspInterface
